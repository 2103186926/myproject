{
  "model": {
    "cfg_hidden_channels": 256,
    "cfg_out_channels": 128,
    "cfg_num_layers": 4,
    "cfg_dropout": 0.3,
    "cfg_pooling": "attention",
    "fcg_hidden_channels": 256,
    "fcg_out_channels": 128,
    "fcg_num_layers": 3,
    "fcg_dropout": 0.3,
    "fcg_pooling": "attention",
    "final_embedding_dim": 256,
    "node_feature_dim": 256,
    "edge_feature_dim": 32,
    "text_embedding_dim": 256,
    "codebert_model_path": "./codebert-base/",
    "use_codebert": true,
    "codebert_max_length": 512,
    "codebert_use_projection": true,
    "codebert_finetune": false
  },
  "training": {
    "cfg_epochs": 100,
    "fcg_epochs": 80,
    "batch_size": 16,
    "learning_rate": 0.001,
    "weight_decay": 0.0005,
    "early_stopping": true,
    "patience": 15,
    "min_delta": 0.001,
    "use_scheduler": true,
    "scheduler_type": "ReduceLROnPlateau",
    "scheduler_patience": 10,
    "scheduler_factor": 0.5,
    "train_ratio": 0.7,
    "val_ratio": 0.15,
    "test_ratio": 0.15,
    "gpu_id": 0,
    "use_gpu": true,
    "num_workers": 4,
    "seed": 42
  },
  "data": {
    "source_dir": "./test_cases_v3",
    "output_dir": "./output_cache_test",
    "log_dir": "./logs",
    "model_dir": "./models",
    "min_nodes": 3,
    "max_nodes": 500,
    "min_edges": 2,
    "cpu_count": null,
    "cache_parsed_ast": true,
    "cache_dir": "./cache"
  },
  "container_escape": {
    "sensitive_api_patterns": [
      "os\\.(system|popen|exec[vl]?[pe]?|spawn[vl]?[pe]?|fork)",
      "subprocess\\.(Popen|call|check_output|check_call|run)",
      "commands\\.(getoutput|getstatusoutput)",
      "eval",
      "exec",
      "compile",
      "__import__",
      "pickle\\.(load|loads|dump|dumps)",
      "marshal\\.(load|loads|dump|dumps)",
      "yaml\\.(load|load_all|unsafe_load)",
      "json\\.(load|loads)",
      "socket\\.(socket|create_connection|create_server)",
      "requests\\.(get|post|put|delete|patch|head|options)",
      "urllib\\.(request|urlopen|urlretrieve)",
      "http\\.client\\.",
      "open\\s*\\(",
      "shutil\\.(copy|copy2|copytree|move|rmtree)",
      "os\\.(remove|unlink|rmdir|mkdir|makedirs|rename|chmod|chown)",
      "pathlib\\.Path\\.(write_text|write_bytes|unlink|rmdir)",
      "/proc/.*",
      "/sys/.*",
      "/dev/.*",
      "cgroup",
      "namespace",
      "docker\\.",
      "kubernetes\\.",
      "containerd\\.",
      "setuid|setgid|seteuid|setegid",
      "sudo|su\\s",
      "chmod\\s+[0-9]*7[0-9]*",
      "tempfile\\.",
      "random\\.",
      "secrets\\.",
      "hashlib\\.",
      "base64\\.",
      "crypt\\.",
      "cryptography\\."
    ],
    "sensitive_path_patterns": [
      "/proc/self/.*",
      "/sys/fs/cgroup/.*",
      "/var/run/docker\\.sock",
      "/etc/passwd",
      "/etc/shadow",
      "/root/.*",
      "\\.ssh/.*",
      "\\.kube/.*"
    ],
    "sensitive_api_weight": 2.0,
    "sensitive_path_weight": 1.5,
    "complexity_weight": 1.0
  }
}